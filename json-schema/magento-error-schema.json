{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Error",
  "title": "Error",
  "type": "object",
  "description": "Standard error response returned for 4xx and 5xx responses.",
  "properties": {
    "message": {
      "type": "string",
      "description": "Human-readable error message."
